# ============================================================
# nas-media-automation configuration
#
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
#
# config.env is git-ignored. NEVER commit real API keys.
#
# All scripts look for this file at <repo-root>/config.env by
# default; override the location with the CONFIG_FILE
# environment variable (bash) or NAS_MEDIA_CONFIG (python).
# ============================================================

# --- Radarr / Sonarr API -------------------------------------
# Find API keys under Settings > General in each app.
RADARR_URL="http://<NAS_IP>:7878"
RADARR_API_KEY="<RADARR_API_KEY>"
SONARR_URL="http://<NAS_IP>:8989"
SONARR_API_KEY="<SONARR_API_KEY>"

# --- Library paths (host paths on the NAS) -------------------
MOVIES_DIR="/volume1/Movies"
TV_DIR="/volume1/TV Shows"
TORRENT_MOVIES_DIR="/volume1/Torrents/movies"
TORRENT_TV_DIR="/volume1/Torrents/tv"

# --- Container path prefixes ---------------------------------
# Radarr/Sonarr run in Docker and report container paths like
# /movies/Title (2020). These prefixes are translated to the
# host paths above.
MOVIE_CONTAINER_PREFIX="/movies/"
TV_CONTAINER_PREFIX="/tv/"

# --- Cold storage (USB archive drive) ------------------------
COLD_ROOT="/mnt/<USB_MOUNT>/Cold"

# --- Working files -------------------------------------------
LOG_DIR="/volume1/docker/scripts/logs"
CANDIDATE_FILE="/volume1/docker/scripts/cold_storage_candidates.json"

# --- Cold storage thresholds ---------------------------------
MOVIE_MIN_SIZE_GB=2
MOVIE_MIN_AGE_DAYS=365
TV_MIN_AGE_DAYS=365

# --- Behaviour -----------------------------------------------
# Unmonitor moved items in Radarr/Sonarr after a verified move
# (recommended: true, otherwise Radarr re-downloads archived
# monitored movies).
UNMONITOR=true
