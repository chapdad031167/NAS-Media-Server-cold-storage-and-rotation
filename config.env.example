# ============================================================
# nas-media-automation configuration
#
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
#
# config.env is git-ignored. NEVER commit real API keys.
#
# All scripts look for this file at <repo-root>/config.env by
# default; override the location with the CONFIG_FILE
# environment variable (bash) or NAS_MEDIA_CONFIG (python).
# ============================================================

# --- Radarr / Sonarr API -------------------------------------
# Find API keys under Settings > General in each app.
RADARR_URL="http://<NAS_IP>:7878"
RADARR_API_KEY="<RADARR_API_KEY>"
SONARR_URL="http://<NAS_IP>:8989"
SONARR_API_KEY="<SONARR_API_KEY>"

# --- Library paths (host paths on the NAS) -------------------
MOVIES_DIR="/volume1/Movies"
TV_DIR="/volume1/TV Shows"
TORRENT_MOVIES_DIR="/volume1/Torrents/movies"
TORRENT_TV_DIR="/volume1/Torrents/tv"

# --- Container path prefixes ---------------------------------
# Radarr/Sonarr run in Docker and report container paths like
# /movies/Title (2020). These prefixes are translated to the
# host paths above.
MOVIE_CONTAINER_PREFIX="/movies/"
TV_CONTAINER_PREFIX="/tv/"

# --- Cold storage (USB archive drive) ------------------------
# Set this to the archive drive's mount point plus a subfolder.
# Find the mount with:   df -h | grep -i usb
# NAS platforms mount USB drives at non-obvious paths (Synology:
# /mnt/@usb/sde1 or /volumeUSB1/usbshare; UGOS uses its own scheme)
# - so confirm with df and set COLD_ROOT to e.g.
# /mnt/@usb/sde1/Cold  or  <your USB mount>/Cold
COLD_ROOT="/mnt/<USB_MOUNT>/Cold"

# --- Working files -------------------------------------------
LOG_DIR="/volume1/docker/scripts/logs"
CANDIDATE_FILE="/volume1/docker/scripts/cold_storage_candidates.json"

# --- Cold storage thresholds ---------------------------------
MOVIE_MIN_SIZE_GB=2
MOVIE_MIN_AGE_DAYS=365
TV_MIN_AGE_DAYS=365

# --- qBittorrent (for torrent_cleanup_api.py) ----------------
# The API-based cleanup removes torrents through qBittorrent so
# the client's state always matches the disk (no broken seeds).
QBT_URL="http://<NAS_IP>:8080"
QBT_USERNAME="<QBT_USERNAME>"
QBT_PASSWORD="<QBT_PASSWORD>"
# A torrent is removable once EITHER goal is met (and its import
# into the library is confirmed)
QBT_MIN_RATIO=1.0
QBT_MIN_SEED_DAYS=7

# --- Tautulli watched guard (optional) -----------------------
# With both set, cold_storage_scan.py skips anything played
# within WATCHED_GUARD_DAYS - release age says "old", watch
# history says "still loved". Leave empty to disable.
#TAUTULLI_URL="http://<NAS_IP>:8181"
#TAUTULLI_API_KEY="<TAUTULLI_API_KEY>"
WATCHED_GUARD_DAYS=180

# --- Behaviour -----------------------------------------------
# Unmonitor moved items in Radarr/Sonarr after a verified move
# (recommended: true, otherwise Radarr re-downloads archived
# monitored movies).
UNMONITOR=true
# Also repoint the item's Radarr/Sonarr path at its cold storage
# location after a verified move, so archived media stays visible
# (and playable via a Plex "Archive" library) instead of showing
# as missing. Requires $COLD_ROOT/Movies and "$COLD_ROOT/TV Shows"
# to be added as root folders in Radarr/Sonarr first.
UPDATE_ARR_PATHS=false

# --- Cold storage rotation -----------------------------------
# Archive manifest (JSON lines, one event per verified move or
# restore). Default: on the cold drive, so it travels with it.
#MANIFEST_FILE="/mnt/<USB_MOUNT>/Cold/cold_storage_manifest.jsonl"
# Capacity target: when > 0, cold_storage_cycle.sh archives
# oldest-first and STOPS once pool usage is at/below this
# percentage. 0 = archive every candidate (original behaviour).
POOL_TARGET_PCT=0

# --- Notifications (optional) --------------------------------
# End-of-run summaries and fatal errors are pushed to any of
# these that are set. Leave empty to disable.
#NTFY_URL="https://ntfy.sh/<your-private-topic>"
#DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/<id>/<token>"

# --- One-tap archive approval (optional) ---------------------
# Turns the weekly scan report into a phone notification with an
# "Approve archive" button; a cron'd approval_poll.sh executes
# cold_storage_cycle.sh --run when (and only when) you tap it.
# Requires NTFY_URL above (the report + button ride on ntfy;
# Discord webhooks can't carry buttons).
#
#   1. APPROVE_URL: a SECOND private ntfy topic, used only for
#      approvals. Both topic URLs are credentials - anyone who
#      knows them can read reports or attempt approvals - so
#      pick unguessable names and treat them like API keys.
#   2. APPROVE_TOKEN: shared secret the button publishes and the
#      poller verifies. Generate one:  openssl rand -base64 24
#      (no commas - ntfy's Actions header is comma-delimited).
#   3. REMOTE_APPROVE=true arms approval_poll.sh; anything else
#      keeps it inert no matter what else is set.
#
# Cron the poller every few minutes (see INSTALL.md Part 5).
#REMOTE_APPROVE=true
#APPROVE_URL="https://ntfy.sh/<a-second-private-topic>"
#APPROVE_TOKEN="<long-random-secret-no-commas>"
# How far back the poller's FIRST run looks for approvals (state
# tracks exact position afterwards). ntfy duration, e.g. 30m, 1h.
#APPROVE_LOOKBACK="30m"

# --- Maintenance ---------------------------------------------
# Delete run logs older than this many days
LOG_RETENTION_DAYS=90
# Where lock files live (prevents overlapping runs).
# Default: .locks/ inside the install directory - a user-owned
# location. Avoid world-writable dirs like /tmp, where another
# local user could squat the lock names.
#LOCK_DIR="/volume1/docker/scripts/nas-media-automation/.locks"
# cold_storage_cycle.sh refuses to --run from a candidate file
# older than this (the library changes; old scans lie)
CANDIDATE_MAX_AGE_DAYS=7
# Protected franchise list (one substring per line, # comments).
# Default: protected_franchises.txt in the repo root.
#PROTECTED_LIST_FILE="/path/to/protected_franchises.txt"
